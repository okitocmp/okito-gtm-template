___TESTS___

scenarios:
- name: Okito CDN script is injected with the correct URL
  code: |-
    // Test data.
    const mockData = {
      websiteKey: 'okito-abc123-def456-d',
      waitForUpdate: 500,
      adsDataRedaction: true,
      urlPassthrough: true,
      developerId: 'dZGJiMm'
    };

    mock('queryPermission', function(permission, url) {
      return true;
    });
    mock('setDefaultConsentState', function(state) {});
    mock('gtagSet', function(settings) {});
    mock('injectScript', function(url, onSuccess, onFailure) {
      assertThat(url).isEqualTo('https://cdn.okito.com/js/okito-abc123-def456-d');
      onSuccess();
    });

    runCode(mockData);

    assertApi('injectScript').wasCalled();
    assertApi('gtmOnSuccess').wasCalled();
- name: Consent Mode v2 defaults are all denied except functionality and security
  code: |-
    const mockData = {
      websiteKey: 'okito-abc123-def456-d',
      waitForUpdate: 500,
      adsDataRedaction: true,
      urlPassthrough: true,
      developerId: 'dZGJiMm'
    };

    let capturedState = null;
    mock('setDefaultConsentState', function(state) {
      capturedState = state;
    });
    mock('gtagSet', function(settings) {});
    mock('queryPermission', function(permission, url) { return true; });
    mock('injectScript', function(url, onSuccess, onFailure) { onSuccess(); });

    runCode(mockData);

    assertThat(capturedState).isNotNull();
    assertThat(capturedState.ad_storage).isEqualTo('denied');
    assertThat(capturedState.analytics_storage).isEqualTo('denied');
    assertThat(capturedState.ad_user_data).isEqualTo('denied');
    assertThat(capturedState.ad_personalization).isEqualTo('denied');
    assertThat(capturedState.functionality_storage).isEqualTo('granted');
    assertThat(capturedState.personalization_storage).isEqualTo('denied');
    assertThat(capturedState.security_storage).isEqualTo('granted');
    assertThat(capturedState.wait_for_update).isEqualTo(500);
- name: Developer ID and ads settings are sent via gtagSet
  code: |-
    const mockData = {
      websiteKey: 'okito-abc123-def456-d',
      waitForUpdate: 500,
      adsDataRedaction: true,
      urlPassthrough: true,
      developerId: 'dZGJiMm'
    };

    let capturedSettings = null;
    mock('gtagSet', function(settings) {
      capturedSettings = settings;
    });
    mock('setDefaultConsentState', function(state) {});
    mock('queryPermission', function(permission, url) { return true; });
    mock('injectScript', function(url, onSuccess, onFailure) { onSuccess(); });

    runCode(mockData);

    assertThat(capturedSettings).isNotNull();
    assertThat(capturedSettings['developer_id.dZGJiMm']).isEqualTo(true);
    assertThat(capturedSettings.ads_data_redaction).isEqualTo(true);
    assertThat(capturedSettings.url_passthrough).isEqualTo(true);
- name: gtmOnFailure is called when inject_script permission is denied
  code: |-
    const mockData = {
      websiteKey: 'okito-abc123-def456-d',
      waitForUpdate: 500,
      adsDataRedaction: true,
      urlPassthrough: true,
      developerId: 'dZGJiMm'
    };

    mock('queryPermission', function(permission, url) {
      return false;
    });
    mock('setDefaultConsentState', function(state) {});
    mock('gtagSet', function(settings) {});

    runCode(mockData);

    assertApi('injectScript').wasNotCalled();
    assertApi('gtmOnFailure').wasCalled();


___NOTES___

Okito CMP — Google Tag Manager Community Template.
Built to mirror Okito's CDN Consent Mode defaults (all denied except
functionality_storage and security_storage, wait_for_update 500).
The Okito CDN script (https://cdn.okito.com/js/{websiteKey}) renders the banner
and issues gtag('consent','update', ...) on a visitor's choice.


